      "runtimeExecutable": ".venv\\Scripts\\python.exe",
      "runtimeArgs": ["-u", "tools/intake_form.py", "--family", "video", "--port", "8765", "--timeout", "1800"],
      "port": 8765
    },
    {
      "name": "intake-form-static",
      "runtimeExecutable": ".venv\\Scripts\\python.exe",
      "runtimeArgs": ["-u", "tools/intake_form.py", "--family", "static", "--port", "8766", "--timeout", "1800"],
      "port": 8766
    }
  ]
}
