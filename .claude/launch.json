{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "editable-timeline-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "--yes",
        "hyperframes",
        "preview",
        "assets/mode-earn/ask-your-phone-for-a-raise/edit/editable-timeline",
        "--port",
        "3017"
      ],
      "port": 3017
    },
    {
