# Copy this file to .env and fill in values from Gianne.
# DO NOT put real keys in this file — it syncs to the shared drive. Real keys live in .env only.

# Higgsfield (AI image/video generation) — needs BOTH the ID and the secret key.
HIGGSFIELD_API_ID=
HIGGSFIELD_API_KEY=

# Google Gemini (LLM — research, scriptwriting). Used instead of OpenRouter for now.
GEMINI_API_KEY=

# OpenRouter (optional fallback LLM — currently using Gemini instead).
OPENROUTER_API_KEY=

# Apify (scraping / research).
APIFY_API_KEY=

# Postiz (social scheduling / posting to TikTok + IG).
POSTIZ_API_KEY=

# HeyGen (AI avatar video).
HEYGEN_API_KEY=

# ElevenLabs (video-use transcription — word-level timing + filler/dead-space detection).
# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
