# Copy this file to .env and fill in real values
# DO NOT commit .env with real keys
#
# You have two ways to set these keys:
#   1. A per-project .env file (copy this file to .env in your working folder).
#      The HyperFrames CLI auto-loads .env from the current directory.
#   2. Shell exports in your ~/.zshrc (or ~/.bashrc), e.g.:
#         export HIGGSFIELD_API_KEY="..."
#      This makes the keys available to every project, no .env needed.
#
# Get the real values from the team vault — never paste keys into any
# committed file, Slack, or chat.

HIGGSFIELD_API_ID=your-higgsfield-api-id
HIGGSFIELD_API_KEY=your-higgsfield-api-key

GEMINI_API_KEY=your-gemini-api-key

APIFY_API_KEY=your-apify-api-key

POSTIZ_API_KEY=your-postiz-api-key

HEYGEN_API_KEY=your-heygen-api-key

# Optional — only needed if you use ElevenLabs for voiceover instead of
# the built-in Kokoro TTS or HeyGen.
# ELEVENLABS_API_KEY=your-elevenlabs-api-key
